@kernel void axpy(const int N, const exampleDtype alpha, @restrict const exampleDtype* x, @restrict const exampleDtype* y, @restrict exampleDtype* ans) {
  @outer for (int o=0; o < N; o+= 1024) {
    @inner for (int i = 0; i < 1024 / numPerThread; ++i) {
      ans[i+o] = alpha * x[i+o] + y[i+o];
    }
  }
}
